{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/carono/.claude/hooks/dejavu-push.sh userprompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/carono/.claude/hooks/dejavu-push.sh pretool"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/carono/.claude/hooks/dejavu-stop.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
